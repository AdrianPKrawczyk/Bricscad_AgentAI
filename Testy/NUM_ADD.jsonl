{"messages":[{"role":"user","content":"Zaznacz opisy DBText na warstwie 'KONSTRUKCJA'. Zmień przekroje dwuteowników (np. IPE 200) powiększając ich wartość o 20."},{"role":"assistant","content":"[SELECT: {\"Mode\": \"New\", \"EntityType\": \"DBText\", \"Conditions\": [{\"Property\": \"Layer\", \"Operator\": \"==\", \"Value\": \"KONSTRUKCJA\"}]}]"},{"role":"user","content":"WYNIK: Zaznaczono 2 obiektów."},{"role":"assistant","content":"[ACTION:READ_PROPERTY {\"Property\": \"TextString\", \"SaveAs\": \"Wartosci\"}]"},{"role":"user","content":"WYNIK: @Wartosci = IPE 200 | IPE 240"},{"role":"assistant","content":"[ACTION:FOREACH {\"Iterable\": \"@Wartosci\", \"Action\": \"TEXT_EDIT\", \"TemplateArgs\": {\"Mode\": \"Replace\", \"FindText\": \"$ITEM1\", \"Text\": \"RPN: CLEAR '$ITEM1' 20 NUM_ADD\"}}]"},{"role":"user","content":"WYNIK: Wykonano instrukcję FOREACH dla 2 elementów."},{"role":"assistant","content":"[MSG: Gotowe! Zaktualizowałem przekroje dwuteowników na warstwie KONSTRUKCJA, powiększając wartości liczbowe w tekstach o 20 za pomocą operatora NUM_ADD.]"}]}
{"messages":[{"role":"user","content":"Zaznacz opisy DBText na warstwie 'KOTY'. Odczytaj ich wartości i obniż rzędne wysokościowe o 1."},{"role":"assistant","content":"[SELECT: {\"Mode\": \"New\", \"EntityType\": \"DBText\", \"Conditions\": [{\"Property\": \"Layer\", \"Operator\": \"==\", \"Value\": \"KOTY\"}]}]"},{"role":"user","content":"WYNIK: Zaznaczono 2 obiektów."},{"role":"assistant","content":"[ACTION:READ_PROPERTY {\"Property\": \"TextString\", \"SaveAs\": \"Rzedne\"}]"},{"role":"user","content":"WYNIK: @Rzedne = + 15.50 | + 12.00"},{"role":"assistant","content":"[ACTION:FOREACH {\"Iterable\": \"@Rzedne\", \"Action\": \"TEXT_EDIT\", \"TemplateArgs\": {\"Mode\": \"Replace\", \"FindText\": \"$ITEM1\", \"Text\": \"RPN: CLEAR '$ITEM1' -1 NUM_ADD\"}}]"},{"role":"user","content":"WYNIK: Wykonano instrukcję FOREACH dla 2 elementów."},{"role":"assistant","content":"[MSG: Gotowe! Zmniejszyłem wartości rzędnych o 1 używając modyfikatora tekstu NUM_ADD z wartością ujemną.]"}]}
{"messages":[{"role":"user","content":"Zaznacz obiekty MText na warstwie 'ZELBET'. Używając natywnej właściwości API 'Text', odczytaj ich zawartość i podnieś klasę betonu z C20/25 o 5 oczek wyżej."},{"role":"assistant","content":"[SELECT: {\"Mode\": \"New\", \"EntityType\": \"MText\", \"Conditions\": [{\"Property\": \"Layer\", \"Operator\": \"==\", \"Value\": \"ZELBET\"}]}]"},{"role":"user","content":"WYNIK: Zaznaczono 2 obiektów."},{"role":"assistant","content":"[ACTION:READ_PROPERTY {\"Property\": \"Text\", \"SaveAs\": \"Klasy\"}]"},{"role":"user","content":"WYNIK: @Klasy = C20/25 | C25/30"},{"role":"assistant","content":"[ACTION:FOREACH {\"Iterable\": \"@Klasy\", \"Action\": \"TEXT_EDIT\", \"TemplateArgs\": {\"Mode\": \"Replace\", \"FindText\": \"$ITEM1\", \"Text\": \"RPN: CLEAR '$ITEM1' 5 NUM_ADD\"}}]"},{"role":"user","content":"WYNIK: Wykonano instrukcję FOREACH dla 2 elementów."},{"role":"assistant","content":"[MSG: Gotowe! Odczytałem czysty tekst z obiektów MText omijając kody RTF i zwiększyłem liczby w klasach betonu o 5.]"}]}
{"messages":[{"role":"user","content":"Zaznacz opisy MText na warstwie 'STAL'. Zmień profile HEB (np. HEB 300) powiększając ich wielkość o 20. Użyj właściwości 'Text'."},{"role":"assistant","content":"[SELECT: {\"Mode\": \"New\", \"EntityType\": \"MText\", \"Conditions\": [{\"Property\": \"Layer\", \"Operator\": \"==\", \"Value\": \"STAL\"}]}]"},{"role":"user","content":"WYNIK: Zaznaczono 2 obiektów."},{"role":"assistant","content":"[ACTION:READ_PROPERTY {\"Property\": \"Text\", \"SaveAs\": \"Profile\"}]"},{"role":"user","content":"WYNIK: @Profile = Profil HEB 300 | HEB 200"},{"role":"assistant","content":"[ACTION:FOREACH {\"Iterable\": \"@Profile\", \"Action\": \"TEXT_EDIT\", \"TemplateArgs\": {\"Mode\": \"Replace\", \"FindText\": \"$ITEM1\", \"Text\": \"RPN: CLEAR '$ITEM1' 20 NUM_ADD\"}}]"},{"role":"user","content":"WYNIK: Wykonano instrukcję FOREACH dla 2 elementów."},{"role":"assistant","content":"[MSG: Gotowe! Zmodyfikowałem rozmiary profili HEB o 20, korzystając z właściwości natywnej 'Text'.]"}]}
{"messages":[{"role":"user","content":"Zaznacz opisy wielowierszowe na warstwie 'PPOZ'. Wykorzystaj uniwersalny alias (Value) do odczytania ich wartości i podnieś klasę odporności ogniowej o 30 minut."},{"role":"assistant","content":"[SELECT: {\"Mode\": \"New\", \"EntityType\": \"MText\", \"Conditions\": [{\"Property\": \"Layer\", \"Operator\": \"==\", \"Value\": \"PPOZ\"}]}]"},{"role":"user","content":"WYNIK: Zaznaczono 2 obiektów."},{"role":"assistant","content":"[ACTION:READ_PROPERTY {\"Property\": \"Value\", \"SaveAs\": \"Odpornosci\"}]"},{"role":"user","content":"WYNIK: @Odpornosci = REI 60 | Ściana REI 90"},{"role":"assistant","content":"[ACTION:FOREACH {\"Iterable\": \"@Odpornosci\", \"Action\": \"TEXT_EDIT\", \"TemplateArgs\": {\"Mode\": \"Replace\", \"FindText\": \"$ITEM1\", \"Text\": \"RPN: CLEAR '$ITEM1' 30 NUM_ADD\"}}]"},{"role":"user","content":"WYNIK: Wykonano instrukcję FOREACH dla 2 elementów."},{"role":"assistant","content":"[MSG: Gotowe! Klasy odporności ogniowej zostały podniesione o 30 minut. Użyłem aliasu 'Value' do bezpiecznego pobrania tekstu.]"}]}
{"messages":[{"role":"user","content":"Zaznacz mteksty na warstwie 'TABELKA'. Podbij w nich numery rewizji o 1 do góry używając aliasu Value."},{"role":"assistant","content":"[SELECT: {\"Mode\": \"New\", \"EntityType\": \"MText\", \"Conditions\": [{\"Property\": \"Layer\", \"Operator\": \"==\", \"Value\": \"TABELKA\"}]}]"},{"role":"user","content":"WYNIK: Zaznaczono 2 obiektów."},{"role":"assistant","content":"[ACTION:READ_PROPERTY {\"Property\": \"Value\", \"SaveAs\": \"Rewizje\"}]"},{"role":"user","content":"WYNIK: @Rewizje = Rev 1.0 | Rysunek Rev 2.0"},{"role":"assistant","content":"[ACTION:FOREACH {\"Iterable\": \"@Rewizje\", \"Action\": \"TEXT_EDIT\", \"TemplateArgs\": {\"Mode\": \"Replace\", \"FindText\": \"$ITEM1\", \"Text\": \"RPN: CLEAR '$ITEM1' 1 NUM_ADD\"}}]"},{"role":"user","content":"WYNIK: Wykonano instrukcję FOREACH dla 2 elementów."},{"role":"assistant","content":"[MSG: Gotowe! Zaktualizowałem numery rewizji we wszystkich opisach o 1.]"}]}
{"messages":[{"role":"user","content":"Zaznacz opisy rur (teksty i mteksty) na warstwie 'RURY'. Powiększ ich średnice DN o 15."},{"role":"assistant","content":"[SELECT: {\"Mode\": \"New\", \"EntityType\": \"*Text\", \"Conditions\": [{\"Property\": \"Layer\", \"Operator\": \"==\", \"Value\": \"RURY\"}]}]"},{"role":"user","content":"WYNIK: Zaznaczono 4 obiektów."},{"role":"assistant","content":"[ACTION:READ_PROPERTY {\"Property\": \"Value\", \"SaveAs\": \"Opisy\"}]"},{"role":"user","content":"WYNIK: @Opisy = DN 50 | DN 100 | DN 150 | DN 200"},{"role":"assistant","content":"[ACTION:FOREACH {\"Iterable\": \"@Opisy\", \"Action\": \"TEXT_EDIT\", \"TemplateArgs\": {\"Mode\": \"Replace\", \"FindText\": \"$ITEM1\", \"Text\": \"RPN: CLEAR '$ITEM1' 15 NUM_ADD\"}}]"},{"role":"user","content":"WYNIK: Wykonano instrukcję FOREACH dla 4 elementów."},{"role":"assistant","content":"[MSG: Gotowe! Przeskanowałem warstwę 'RURY' i za pomocą uniwersalnego edytora tekstów dodałem 15 do każdej znalezionej średnicy używając aliasu Value.]"}]}
{"messages":[{"role":"user","content":"Zaznacz wszystkie teksty i mteksty na warstwie 'OZNACZENIA'. Odczytaj ich pozycje i przesuń numerację o 10 oczek w górę."},{"role":"assistant","content":"[SELECT: {\"Mode\": \"New\", \"EntityType\": \"DBText, MText\", \"Conditions\": [{\"Property\": \"Layer\", \"Operator\": \"==\", \"Value\": \"OZNACZENIA\"}]}]"},{"role":"user","content":"WYNIK: Zaznaczono 4 obiektów."},{"role":"assistant","content":"[ACTION:READ_PROPERTY {\"Property\": \"Value\", \"SaveAs\": \"Pozycje\"}]"},{"role":"user","content":"WYNIK: @Pozycje = Poz. 100 | Poz. 110 | Poz. 120 | Poz. 130"},{"role":"assistant","content":"[ACTION:FOREACH {\"Iterable\": \"@Pozycje\", \"Action\": \"TEXT_EDIT\", \"TemplateArgs\": {\"Mode\": \"Replace\", \"FindText\": \"$ITEM1\", \"Text\": \"RPN: CLEAR '$ITEM1' 10 NUM_ADD\"}}]"},{"role":"user","content":"WYNIK: Wykonano instrukcję FOREACH dla 4 elementów."},{"role":"assistant","content":"[MSG: Zrobione! Numeracja wszystkich pozycji (na mieszanych typach tekstu) została przesunięta o 10.]"}]}
{"messages":[{"role":"user","content":"Znajdź na warstwie 'IZOLACJE' dowolne teksty jedno i wielowierszowe (*Text). Powiększ grubość izolacji o 5."},{"role":"assistant","content":"[SELECT: {\"Mode\": \"New\", \"EntityType\": \"*Text\", \"Conditions\": [{\"Property\": \"Layer\", \"Operator\": \"==\", \"Value\": \"IZOLACJE\"}]}]"},{"role":"user","content":"WYNIK: Zaznaczono 4 obiektów."},{"role":"assistant","content":"[ACTION:READ_PROPERTY {\"Property\": \"Value\", \"SaveAs\": \"Grubosci\"}]"},{"role":"user","content":"WYNIK: @Grubosci = Grubość 10 cm | Grubość 15 cm | 20 cm | Grubość 25 cm"},{"role":"assistant","content":"[ACTION:FOREACH {\"Iterable\": \"@Grubosci\", \"Action\": \"TEXT_EDIT\", \"TemplateArgs\": {\"Mode\": \"Replace\", \"FindText\": \"$ITEM1\", \"Text\": \"RPN: CLEAR '$ITEM1' 5 NUM_ADD\"}}]"},{"role":"user","content":"WYNIK: Wykonano instrukcję FOREACH dla 4 elementów."},{"role":"assistant","content":"[MSG: Gotowe! Grubość izolacji we wszystkich opisach na warstwie została powiększona o 5.]"}]}
{"messages":[{"role":"user","content":"Zaznacz wszystkie opisy tekstowe (*Text) z warstwy 'ELEKTRYKA'. Zwiększ przydziały mocy o 5 kW używając kalkulatora RPN i aliasu Value."},{"role":"assistant","content":"[SELECT: {\"Mode\": \"New\", \"EntityType\": \"*Text\", \"Conditions\": [{\"Property\": \"Layer\", \"Operator\": \"==\", \"Value\": \"ELEKTRYKA\"}]}]"},{"role":"user","content":"WYNIK: Zaznaczono 4 obiektów."},{"role":"assistant","content":"[ACTION:READ_PROPERTY {\"Property\": \"Value\", \"SaveAs\": \"Moc\"}]"},{"role":"user","content":"WYNIK: @Moc = Moc 10 kW | Moc 15 kW | Zasilanie 20 kW | 25 kW"},{"role":"assistant","content":"[ACTION:FOREACH {\"Iterable\": \"@Moc\", \"Action\": \"TEXT_EDIT\", \"TemplateArgs\": {\"Mode\": \"Replace\", \"FindText\": \"$ITEM1\", \"Text\": \"RPN: CLEAR '$ITEM1' 5 NUM_ADD\"}}]"},{"role":"user","content":"WYNIK: Wykonano instrukcję FOREACH dla 4 elementów."},{"role":"assistant","content":"[MSG: Wykonano. Przydziały mocy zostały zwiększone o 5 we wszystkich mieszanych opisach.]"}]}